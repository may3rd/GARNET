# Backend environment example
# Copy to backend/.env for a backend-only setup.
# backend/api.py loads both:
# - /Users/maetee/Code/GARNET/.env
# - /Users/maetee/Code/GARNET/backend/.env

# Server
HOST=localhost
PORT=8001

# Upload limits
MAX_FILE_SIZE_MB=50
ALLOWED_IMAGE_EXTENSIONS=.jpg,.jpeg,.png,.webp,.bmp,.tiff

# Default detection settings
DEFAULT_CONF_THRESHOLD=0.8
DEFAULT_IMAGE_SIZE=640
DEFAULT_OVERLAP_RATIO=0.2

# Gemini / OpenRouter
# Required for:
# - detection runs using selected_model=gemini
# - pipeline OCR runs using ocr_route=gemini
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-3-flash-preview
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_TEMPERATURE=0.7

# OCR runtime
OCR_CACHE_ENABLED=true
OCR_LANGUAGES=en
OCR_GPU=true

# Logging
LOG_LEVEL=INFO
LOG_FILE=garnet.log
